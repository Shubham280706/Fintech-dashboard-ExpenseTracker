{
  "name": "fintech-dashboard-expensetracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "frontend": "npm --prefix frontend start",
    "backend": "cd backend && ../.venv/bin/uvicorn server:app --reload --host 127.0.0.1 --port 8000",
    "dev": "concurrently -k -n frontend,backend -c green,blue \"npm --prefix frontend start\" \"cd backend && ../.venv/bin/uvicorn server:app --reload --host 127.0.0.1 --port 8000\"",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
